---
import Base from '../layouts/Base.astro';
---

<Base title="Zgłoś temat" description="Call for Papers — zgłoś temat prezentacji na Konferencję Tłumaczy 2026.">
  <section class="page-hero">
    <div class="container">
      <p class="page-hero__overline">Call for Papers</p>
      <h1>Zgłoś swój temat</h1>
      <p class="page-hero__lead">
        Masz temat, którym chcesz się podzielić z branżą? Zgłoś go — uczestnicy zagłosują na najciekawsze propozycje.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow text-center">
      <span class="badge">Wkrótce</span>
      <h2 class="mt-md">Formularz zgłoszeniowy w przygotowaniu</h2>
      <p class="text-muted mt-sm">
        Przyjmowanie tematów ruszy wkrótce. Zapisz się na newsletter, żeby nie przegapić otwarcia.
      </p>
      <a href="mailto:konferencja@zztp.pl?subject=Zapis na newsletter" class="btn btn--primary mt-md">
        Powiadom mnie
      </a>
    </div>
  </section>
</Base>

<style>
  .page-hero {
    padding: var(--spacing-xl) 0 var(--spacing-lg);
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
  }
  .page-hero__overline {
    font-size: 0.85rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--color-accent-dark); margin-bottom: var(--spacing-xs);
  }
  .page-hero__lead {
    font-size: 1.2rem; color: var(--color-text-muted); max-width: 52ch; margin-top: var(--spacing-sm);
  }
</style>
