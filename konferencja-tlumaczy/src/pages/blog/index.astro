---
import Base from '../../layouts/Base.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Blog" description="Aktualności i artykuły o Konferencji Tłumaczy 2026.">
  <section class="page-hero">
    <div class="container">
      <p class="page-hero__overline">Blog</p>
      <h1>Aktualności</h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {posts.length === 0 ? (
        <p class="text-muted text-center">Wpisy wkrótce. Wróć niedługo!</p>
      ) : (
        <div class="grid grid--2">
          {posts.map(post => (
            <BlogCard
              href={`/blog/${post.slug}/`}
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              image={post.data.image}
            />
          ))}
        </div>
      )}
    </div>
  </section>
</Base>

<style>
  .page-hero {
    padding: var(--spacing-xl) 0 var(--spacing-lg);
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
  }
  .page-hero__overline {
    font-size: 0.85rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--color-accent-dark); margin-bottom: var(--spacing-xs);
  }
</style>
