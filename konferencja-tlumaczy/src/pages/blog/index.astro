---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Blog" description="Aktualności i artykuły o Konferencji Tłumaczy 2026.">
  <section class="page-hero">
    <div class="container">
      <p class="page-hero__overline">Blog</p>
      <h1>Aktualności</h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {posts.length === 0 ? (
        <p class="text-muted text-center">Wpisy wkrótce. Wróć niedługo!</p>
      ) : (
        <div class="grid grid--2">
          {posts.map(post => (
            <a href={`/blog/${post.slug}/`} class="blog-card card">
              {post.data.image && (
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="blog-card__image"
                  loading="lazy"
                />
              )}
              <div class="blog-card__body">
                <time class="blog-card__date" datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('pl-PL', {
                    day: 'numeric',
                    month: 'long',
                    year: 'numeric',
                  })}
                </time>
                <h3>{post.data.title}</h3>
                <p class="text-muted">{post.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Base>

<style>
  .page-hero {
    padding: var(--spacing-xl) 0 var(--spacing-lg);
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
  }
  .page-hero__overline {
    font-size: 0.85rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--color-accent-dark); margin-bottom: var(--spacing-xs);
  }
  .blog-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }
  .blog-card__image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: var(--radius) var(--radius) 0 0;
    margin: calc(-1 * var(--spacing-md));
    margin-bottom: var(--spacing-sm);
    width: calc(100% + 2 * var(--spacing-md));
  }
  .blog-card__date {
    font-size: 0.8rem;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .blog-card__body h3 {
    margin-top: 0.3rem;
    color: var(--color-primary-dark);
  }
</style>
