---
const year = new Date().getFullYear();

const socialLinks = [
  { label: 'Facebook', abbr: 'FB', href: 'https://www.facebook.com/KonferencjaTlumaczy' },
  { label: 'LinkedIn', abbr: 'LI', href: 'https://www.linkedin.com/company/konferencja-t%C5%82umaczy/' },
];
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__col">
      <p class="footer__heading">Konferencja Tłumaczy {year}</p>
      <p>26 września 2026 · Warszawa</p>
    </div>
    <div class="footer__col">
      <p class="footer__heading">Kontakt i organizator</p>
      <p>Textem Maria Szpor Anna Konieczna-Purchała sp.j.</p>
      <p>ul. Belwederska 26/30 lok. 9, Warszawa</p>
      <p>NIP: 7010398717</p>
      <p class="footer__email"><a href="mailto:info@konferencja-tlumaczy.pl">info@konferencja-tlumaczy.pl</a></p>
    </div>
    <div class="footer__col">
      <p class="footer__heading">Śledź nas</p>
      <div class="footer__social">
        {socialLinks.map(link => (
          <a href={link.href} target="_blank" rel="noopener" aria-label={link.label}>
            {link.abbr}
          </a>
        ))}
      </div>
      <div class="footer__legal">
        <a href="/regulamin/">Regulamin</a>
        <a href="/polityka-prywatnosci/">Polityka prywatności</a>
      </div>
    </div>
  </div>
  <div class="footer__bottom">
    <p>&copy; {year} Textem. Wszelkie prawa zastrzeżone.</p>
  </div>
</footer>

<style>
  .footer__col p {
    margin-bottom: 0.25rem;
  }

  .footer__heading {
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem !important;
  }

  .footer__email {
    margin-top: 0.5rem !important;
  }

  .footer__social {
    display: flex;
    gap: 1rem;
    margin-top: 0.25rem;
  }

  .footer__legal {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    margin-top: 0.75rem;
  }

  .footer__legal a {
    font-size: 0.85rem;
  }

  .footer__bottom {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--spacing-md) var(--spacing-md) 0;
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-text-light);
    border-top: 1px solid var(--color-border);
    margin-top: var(--spacing-md);
  }

  .footer__bottom p {
    margin-bottom: 0;
    max-width: none;
  }
</style>
