---
const year = new Date().getFullYear();

const socialLinks = [
  { label: 'Facebook', abbr: 'FB', href: 'https://www.facebook.com/KonferencjaTlumaczy' },
  { label: 'LinkedIn', abbr: 'LI', href: 'https://www.linkedin.com/company/konferencja-t%C5%82umaczy/' },
];
---

<footer class="footer">
  <div class="footer__inner">
    <div>
      <p><strong>Konferencja Tłumaczy {year}</strong></p>
      <p>26 września 2026 · Warszawa</p>
    </div>
    <div>
      <p><strong>Kontakt</strong></p>
      <p><a href="mailto:kontakt@konferencjatlumaczy.pl">kontakt@konferencjatlumaczy.pl</a></p>
    </div>
    <div>
      <p><strong>Śledź nas</strong></p>
      <div class="footer__social">
        {socialLinks.map(link => (
          <a href={link.href} target="_blank" rel="noopener" aria-label={link.label}>
            {link.abbr}
          </a>
        ))}
      </div>
    </div>
  </div>
  <div class="container text-center mt-md" style="font-size: 0.8rem; color: var(--color-text-light);">
    <p>&copy; {year} Konferencja Tłumaczy. Wszelkie prawa zastrzeżone.</p>
  </div>
</footer>

<style>
  .footer__social {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
  }
</style>
