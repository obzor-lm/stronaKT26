# ============================================
# KONFERENCJA TŁUMACZY — zmienne środowiskowe
# Skopiuj do .env i uzupełnij wartości
# ============================================

# n8n Webhooks
N8N_WEBHOOK_CFP=https://twoj-n8n.pl/webhook/cfp-submit
N8N_WEBHOOK_VOTE=https://twoj-n8n.pl/webhook/cfp-vote
N8N_WEBHOOK_EXPORT_CFP=https://twoj-n8n.pl/webhook/export-cfp

# Google Sheets
GOOGLE_SHEETS_ID=xxx
GOOGLE_API_KEY=xxx

# Deploy — FTP
FTP_HOST=ftp.twojserwer.pl
FTP_USER=user
FTP_PASS=pass

# Deploy — SSH (alternatywa)
# SSH_USER=user
# SSH_HOST=twojserwer.pl
# SSH_PATH=/public_html/konferencja/
